      "default": "./types/api/clips.ts"
    },
    "./api/common.js": {
      "types": "./dist/api/common.d.ts",
      "default": "./types/api/common.ts"
    },
    "./api/download.js": {
      "types": "./dist/api/download.d.ts",
      "default": "./types/api/download.ts"
    },
    "./api/groups.js": {
      "types": "./dist/api/groups.d.ts",
      "default": "./types/api/groups.ts"
    },
    "./api/imageViewHistory.js": {
      "types": "./dist/api/imageViewHistory.d.ts",
      "default": "./types/api/imageViewHistory.ts"
    },
    "./api/ratings.js": {
      "types": "./dist/api/ratings.d.ts",
